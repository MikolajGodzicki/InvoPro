<Window x:Class="InvoPro.Views.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostyka bazy danych" Height="400" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Diagnostyka bazy danych" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="LogTextBox" TextWrapping="Wrap" IsReadOnly="True" 
                     Background="#F5F5F5" FontFamily="Consolas" FontSize="12"/>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="Odswiez diagnostyke" Click="RefreshButton_Click" 
                    Width="150" Height="30" Margin="0,0,10,0"/>
            <Button Content="Reset bazy danych" Click="ResetButton_Click" 
                    Width="150" Height="30" Margin="10,0,0,0" Background="#E74C3C" Foreground="White"/>
        </StackPanel>
        
        <Button Grid.Row="3" Content="Zamknij" Click="CloseButton_Click" 
                Width="100" Height="30" Margin="0,10,0,0" HorizontalAlignment="Right"/>
    </Grid>
</Window>