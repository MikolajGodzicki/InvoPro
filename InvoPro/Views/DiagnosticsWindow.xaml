<Window x:Class="InvoPro.Views.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostyka bazy danych" Height="400" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Diagnostyka bazy danych" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="LogTextBox" TextWrapping="Wrap" IsReadOnly="True" 
                     Background="#F5F5F5" FontFamily="Consolas" FontSize="12"/>
        </ScrollViewer>
        
        <Button Grid.Row="2" Content="Zamknij" Click="CloseButton_Click" 
                Width="100" Height="30" Margin="0,10,0,0" HorizontalAlignment="Right"/>
    </Grid>
</Window>