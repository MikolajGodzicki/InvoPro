<Window x:Class="InvoPro.Views.CompanySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ustawienia firmy" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#34495E" Padding="15" Margin="0,0,0,20" CornerRadius="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Ustawienia firmy" 
                           FontSize="18" FontWeight="Bold" 
                           Foreground="White"/>
            </StackPanel>
        </Border>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Nazwa firmy:*" 
                               VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Height="25" Padding="5" BorderBrush="#34495E" BorderThickness="1"/>
                </Grid>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Adres:*" 
                               VerticalAlignment="Top" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             Height="60" Padding="5" TextWrapping="Wrap" AcceptsReturn="True"
                             BorderBrush="#34495E" BorderThickness="1"/>
                </Grid>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="NIP:*" 
                               VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding Nip, UpdateSourceTrigger=PropertyChanged}"
                             Height="25" Padding="5" FontFamily="Consolas"
                             BorderBrush="#34495E" BorderThickness="1"/>
                </Grid>
                
                <Separator Margin="0,10"/>
                
                <Grid Margin="0,15,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="REGON:" 
                               VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding Regon, UpdateSourceTrigger=PropertyChanged}"
                             Height="25" Padding="5"
                             BorderBrush="#34495E" BorderThickness="1"/>
                </Grid>
                
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="GLN:" 
                               VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding Gln, UpdateSourceTrigger=PropertyChanged}"
                             Height="25" Padding="5"
                             BorderBrush="#34495E" BorderThickness="1"/>
                </Grid>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Domyślnie wystawił:" 
                               VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" 
                             Text="{Binding DefaultIssuedBy, UpdateSourceTrigger=PropertyChanged}"
                             Height="25" Padding="5"
                             BorderBrush="#34495E" BorderThickness="1"/>
                </Grid>
                
                <Border Background="#ECF0F1" Padding="10" Margin="0,10,0,0" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="Informacje:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="- Pola oznaczone * sa wymagane" FontSize="11"/>
                        <TextBlock Text="- NIP musi skladac sie z 10 cyfr" FontSize="11"/>
                        <TextBlock Text="- Dane beda wyswietlane na fakturach jako sprzedawca" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <Border Grid.Row="1" Background="#2C3E50" Opacity="0.8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Ladowanie danych..." 
                           Foreground="White" FontSize="14" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <ProgressBar IsIndeterminate="True" Width="150" Height="8"/>
            </StackPanel>
        </Border>
        
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1" Content="Zapisz" 
                    Command="{Binding SaveCommand}"
                    Background="#27AE60" Foreground="White" 
                    Padding="20,8" Margin="0,0,10,0" FontWeight="Bold"
                    BorderThickness="0" MinWidth="80" Cursor="Hand"/>
            
            <Button Grid.Column="2" Content="Anuluj" 
                    Command="{Binding CancelCommand}"
                    Background="#95A5A6" Foreground="White" 
                    Padding="20,8" FontWeight="Bold"
                    BorderThickness="0" MinWidth="80" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>