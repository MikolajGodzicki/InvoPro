<Window x:Class="InvoPro.Views.ContractorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InvoPro.ViewModels"
        Title="Lista kontrahentów" Height="650" Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.DataContext>
        <vm:ContractorsViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Contractors}"
                  SelectedItem="{Binding SelectedContractor}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="NIP" Binding="{Binding Nip}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="Adres" Binding="{Binding Address}" Width="220" IsReadOnly="True"/>
                <DataGridTextColumn Header="REGON" Binding="{Binding Regon}" Width="120" IsReadOnly="True"/>
                <DataGridTextColumn Header="GLN" Binding="{Binding Gln}" Width="150" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Background="#ECF0F1" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Nazwa:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,8"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="NIP:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,8"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Nip, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Adres:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,8"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="REGON:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,8"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Regon, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="GLN:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Gln, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Nowy" Command="{Binding NewContractorCommand}" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Zapisz" Command="{Binding SaveContractorCommand}" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Usuń" Command="{Binding DeleteContractorCommand}" Margin="0,0,8,0" Padding="12,6"/>
            <Button Content="Zamknij" IsCancel="True" Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
