<Window x:Class="InvoPro.Views.InvoiceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="800" Width="900"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#34495E" Padding="15" Margin="0,0,0,20">
            <TextBlock Text="{Binding WindowTitle}" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        
        <TabControl Grid.Row="1">
            <TabItem Header="Dane faktury">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="10">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Numer faktury:" 
                                       VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding Number, UpdateSourceTrigger=PropertyChanged}"
                                     Height="25" Margin="0,0,10,0" Padding="5"/>
                            <Button Grid.Column="2" Content="Generuj" 
                                    Command="{Binding GenerateNumberCommand}"
                                    Height="25" Width="70"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Data wystawienia:" 
                                       VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                            <DatePicker Grid.Column="1" SelectedDate="{Binding IssueDate}" Height="25"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Termin platnosci:" 
                                       VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                            <DatePicker Grid.Column="1" SelectedDate="{Binding DueDate}" Height="25"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Nazwa klienta:" 
                                       VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}" Height="25" Padding="5"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Adres klienta:" 
                                       VerticalAlignment="Top" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding ClientAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Height="60" Padding="5" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="NIP klienta:" 
                                       VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding ClientNip, UpdateSourceTrigger=PropertyChanged}" Height="25" Padding="5"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Opis:" 
                                       VerticalAlignment="Top" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     Height="80" Padding="5" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="Pozycje faktury">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Dodaj pozycje" Command="{Binding AddItemCommand}"
                                Background="#27AE60" Foreground="White" 
                                Padding="10,5" Margin="0,0,10,0" BorderThickness="0"/>
                        <Button Content="Usun pozycje" Command="{Binding DeleteItemCommand}"
                                Background="#E74C3C" Foreground="White" 
                                Padding="10,5" BorderThickness="0"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding Invoice.Items}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              Background="White">
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Opis" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                            <DataGridTextColumn Header="Ilosc" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Width="60"/>
                            <DataGridTextColumn Header="Jednostka" Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                            <DataGridTextColumn Header="Cena netto (PLN)" Binding="{Binding UnitPriceNet, UpdateSourceTrigger=PropertyChanged, StringFormat='F2'}" Width="110"/>
                            <DataGridTextColumn Header="Cena brutto (PLN)" Binding="{Binding UnitPriceGross, UpdateSourceTrigger=PropertyChanged, StringFormat='F2'}" Width="110"/>
                            <DataGridTextColumn Header="Rabat %" Binding="{Binding DiscountPercentage, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}" Width="70"/>
                            <DataGridTextColumn Header="VAT %" Binding="{Binding VatRate, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}" Width="60"/>
                            <DataGridTextColumn Header="Wartosc netto (PLN)" Binding="{Binding TotalNet, Mode=OneWay, StringFormat='F2'}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Wartosc brutto (PLN)" Binding="{Binding TotalGross, Mode=OneWay, StringFormat='F2'}" Width="120" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <Border Grid.Row="2" Background="#ECF0F1" Padding="15" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="PODSUMOWANIE:" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Suma netto:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalNet, StringFormat='{}{0:F2} PLN'}" FontSize="14" FontWeight="Bold" Foreground="#27AE60"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock Text="VAT:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalVat, StringFormat='{}{0:F2} PLN'}" FontSize="14" FontWeight="Bold" Foreground="#F39C12"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                                <TextBlock Text="Suma brutto:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:F2} PLN'}" FontSize="16" FontWeight="Bold" Foreground="#E74C3C"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
        
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="1" Content="Zapisz" 
                    Command="{Binding SaveCommand}"
                    Background="#27AE60" Foreground="White" 
                    Padding="20,8" Margin="0,0,10,0" FontWeight="Bold"
                    BorderThickness="0" MinWidth="80"/>
            
            <Button Grid.Column="2" Content="Anuluj" 
                    Command="{Binding CancelCommand}"
                    Background="#95A5A6" Foreground="White" 
                    Padding="20,8" FontWeight="Bold"
                    BorderThickness="0" MinWidth="80"/>
        </Grid>
    </Grid>
</Window>